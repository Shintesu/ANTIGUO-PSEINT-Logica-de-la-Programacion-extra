Algoritmo Practica013CalcularAreaCirculo
	
	// Calcular el área de un círculo dado su radio
	// AreaCírculo = pi * radio ^2
	
	Definir radio, area como real
	
	Escribir "Ingrese el radio del círculo"
	Leer radio
	
	area = 3.14159265358 * radio * radio
	
	Escribir "El área del círculo es de ", area
	
FinAlgoritmo
