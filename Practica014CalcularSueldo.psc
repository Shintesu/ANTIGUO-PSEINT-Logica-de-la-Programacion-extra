Algoritmo Practica014CalcularSueldo
	
	//Calcular el salario semanal de un trabajador
	//dado su salario diario y la cantidad de días en la semana
	
	Definir SalDiario, SalSemanal Como Real
	Definir CantDias Como Entero
	
	Escribir  "Ingrese el salario diario"
	Leer SalDiario
	Escribir  "Ingrese la cantidad de días trabajados"
	Leer CantDias
	
	SalSemanal = SalDiario * CantDias
	
	Escribir  "El salario semanal de la persona es de: ", SalSemanal
	
FinAlgoritmo
