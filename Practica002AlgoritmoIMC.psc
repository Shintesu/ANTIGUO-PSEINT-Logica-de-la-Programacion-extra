Algoritmo Practica002AlgoritmoIMC
	
	Definir  peso, estatura, IMC Como Real
	
	Escribir  ("Imgrese su peso en Kg")
	Leer peso
	Escribir  ("Imgrese su estatura en metros")
	Leer estatura
	
	IMC = peso/(estatura*estatura)
	
	Escribir  "Su Índice de Masa Corporal IMC es: " IMC
	
FinAlgoritmo
